# =============================================================================
# Atlas Platform — Variabili d'Ambiente per Docker
# =============================================================================
# Copia questo file in .env: cp .env.docker.example .env
# Compila tutti i valori prima di avviare i container
# =============================================================================

# Ambiente
NODE_ENV=production
PORT=3000

# Database MySQL (il servizio Docker si chiama "mysql")
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CAMBIA_QUESTA_PASSWORD
DB_NAME=pt_saas_db
DB_POOL_SIZE=50

# JWT Authentication
# Genera secrets con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERA_UN_SECRET_SICURO
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=GENERA_UN_ALTRO_SECRET_SICURO
JWT_REFRESH_EXPIRES_IN=3d

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourapp.com

# Web Push (VAPID Keys)
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourapp.com

# Firebase (Push Notifications - opzionale)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Frontend URL (CORS) — in Docker, nginx serve sulla porta 80
FRONTEND_URL=http://localhost

# Frontend Build Args (opzionali, per docker-compose build)
VITE_API_URL=
VITE_SOCKET_URL=

# Google Calendar API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# Google OAuth (Login Sociale)
GOOGLE_AUTH_REDIRECT_URI=http://localhost/api/auth/oauth/google/callback

# GitHub OAuth (Login Sociale)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost/api/auth/oauth/github/callback

# Discord OAuth (Login Sociale)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost/api/auth/oauth/discord/callback

# Microsoft Graph API (Outlook)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost/api/auth/microsoft/callback

# Stripe (Pagamenti)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Logging
LOG_LEVEL=info

# Sentry — Error Tracking (opzionale)
SENTRY_DSN=
